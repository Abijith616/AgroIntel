// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Sample model - you can modify this based on your needs
model User {
  id            Int             @id @default(autoincrement())
  email         String          @unique
  username      String          @unique
  password      String
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  passwordReset PasswordReset[]
  crops         Crop[]
  expenses      Expense[]
}

model PasswordReset {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  otp       String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}


model Crop {
  id         Int       @id @default(autoincrement())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     Int
  name       String
  landVolume Float
  landUnit   String
  phase      String
  country    String
  state      String
  district   String
  place      String
  latitude   Float?
  longitude  Float?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  expenses   Expense[]
}

model Expense {
  id          Int      @id @default(autoincrement())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      Int
  crop        Crop?    @relation(fields: [cropId], references: [id], onDelete: SetNull)
  cropId      Int?
  category    String   // Seeds, Fertilizer, Labor, Irrigation, Pesticides, Equipment, Other
  amount      Float
  description String
  date        DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Scheme {
  id              Int      @id @default(autoincrement())
  name            String
  description     String
  type            String   // Central, State, etc.
  link            String?
  // We'll store applicable crops as a comma-separated string for simplicity in SQLite 
  // or use JSON if supported/needed, but string match is easier for "contains"
  applicableCrops String   
  benefits        String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
